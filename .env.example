# Copy this to .env (or export these directly) when running things OUTSIDE
# docker-compose -- e.g. running train.py or the API on your host machine
# while Postgres/MLflow run in Docker. docker-compose.yml sets these
# automatically for the containerized services; this file is for the
# "half in Docker, half on host" case (most common while developing).

# Postgres connection for the monitoring schema (prediction_log,
# drift_check, feature_reference_distribution) -- NOT MLflow's own
# backend store, which is configured separately inside mlflow.Dockerfile.
MONITORING_DATABASE_URL=postgresql+psycopg2://ccr_user:ccr_password@localhost:5432/quantum_stock_mlops

# Where train.py, the registry, and the API look for the MLflow tracking
# server. Point this at the dockerized mlflow service's exposed port when
# running train.py from your host machine.
MLFLOW_TRACKING_URI=http://localhost:5000

# Shared secret for the /admin/refresh-and-check-drift endpoint. Must
# match between the backend service and whatever calls that endpoint
# (scripts/refresh_and_check_drift.py, or your own curl/cron). Change this
# to something real before this is ever exposed beyond localhost.
ADMIN_API_TOKEN=local-dev-token
